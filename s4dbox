#!/usr/bin/env bash
#═══════════════════════════════════════════════════════════════════════════════
#  s4dbox — Lightweight Universal Seedbox Manager
#═══════════════════════════════════════════════════════════════════════════════
#
#  A modular, platform-independent seedbox management tool.
#  Supports: Debian/Ubuntu, Arch, RHEL/Fedora/Rocky/Alma
#  Architectures: x86_64, ARM64
#
#  Usage:
#    sudo ./s4dbox              # Launch TUI
#    sudo ./s4dbox install      # Run guided first-time setup
#    sudo ./s4dbox monitor      # Jump to system monitor
#    sudo ./s4dbox tune         # Apply system tuning
#    sudo ./s4dbox help         # Show help
#
#═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

S4D_VERSION="1.0.0"

# ─── Resolve script directory (follow symlinks) ───
_s4d_source="${BASH_SOURCE[0]}"
while [[ -L "$_s4d_source" ]]; do
    _s4d_dir="$(cd "$(dirname "$_s4d_source")" && pwd)"
    _s4d_source="$(readlink "$_s4d_source")"
    [[ "$_s4d_source" != /* ]] && _s4d_source="${_s4d_dir}/${_s4d_source}"
done
S4D_BASE_DIR="$(cd "$(dirname "$_s4d_source")" && pwd)"
unset _s4d_source _s4d_dir
export S4D_BASE_DIR

# ─── Root Check ───
if [[ $EUID -ne 0 ]]; then
    echo "s4dbox requires root privileges. Run with sudo."
    exit 1
fi

# ─── Source Libraries ───
source "${S4D_BASE_DIR}/lib/colors.sh"
source "${S4D_BASE_DIR}/lib/logging.sh"
source "${S4D_BASE_DIR}/lib/system.sh"
source "${S4D_BASE_DIR}/lib/config.sh"
source "${S4D_BASE_DIR}/lib/users.sh"

# ─── Source Modules ───
source "${S4D_BASE_DIR}/modules/tui.sh"
source "${S4D_BASE_DIR}/modules/monitor.sh"
source "${S4D_BASE_DIR}/modules/app_manager.sh"
source "${S4D_BASE_DIR}/modules/tune.sh"
source "${S4D_BASE_DIR}/modules/nginx.sh"
source "${S4D_BASE_DIR}/modules/security.sh"
source "${S4D_BASE_DIR}/modules/storage.sh"
source "${S4D_BASE_DIR}/modules/network.sh"

# ─── Initialize ───
init() {
    log_init
    config_init
    detect_system
    config_load
    log_info "s4dbox ${S4D_VERSION} started on ${S4D_OS_PRETTY} (${S4D_ARCH})"
}

# ─── Banner ───
show_banner() {
    printf "${BOLD}${CYAN}"
    cat <<'BANNER'

    ███████╗██╗  ██╗██████╗ ██████╗  ██████╗ ██╗  ██╗
    ██╔════╝██║  ██║██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝
    ███████╗███████║██║  ██║██████╔╝██║   ██║ ╚███╔╝ 
    ╚════██║╚════██║██║  ██║██╔══██╗██║   ██║ ██╔██╗ 
    ███████║     ██║██████╔╝██████╔╝╚██████╔╝██╔╝ ██╗
    ╚══════╝     ╚═╝╚═════╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝
                                                
BANNER
    printf "${RESET}"
    printf "    ${DIM}Lightweight Universal Seedbox Manager v${S4D_VERSION}${RESET}\n"
    printf "    ${DIM}${S4D_OS_PRETTY} | ${S4D_ARCH} | ${S4D_MEM_TOTAL_MB}MB RAM${RESET}\n\n"
}

# ─── First-Time Setup ───
first_time_setup() {
    clear
    show_banner
    msg_header "First-Time Setup"
    
    msg_info "Detected: ${S4D_OS_PRETTY} (${S4D_DISTRO_FAMILY}) on ${S4D_ARCH}"
    echo
    
    # Update packages
    if tui_confirm "Update system packages?"; then
        spinner_start "Updating packages"
        pkg_update 2>/dev/null
        spinner_stop 0
    fi
    
    # Install dependencies
    spinner_start "Installing core dependencies"
    install_core_deps 2>/dev/null
    spinner_stop 0
    
    # User setup
    local username
    if [[ -z "$(get_seedbox_user)" ]]; then
        username="$(prompt_user_setup)"
    else
        username="$(get_seedbox_user)"
        msg_info "Existing user found: ${username}"
    fi
    
    echo
    
    # App selection
    msg_step "Select applications to install"
    echo
    local selected_apps
    selected_apps=$(tui_checkbox_menu "Select Applications" \
        "qBittorrent" \
        "Jellyfin" \
        "Plex" \
        "FileBrowser" \
        "rTorrent" \
        "ruTorrent" \
        "Tailscale")
    
    if [[ $? -eq 0 ]] && [[ -n "$selected_apps" ]]; then
        while IFS= read -r app_display; do
            local app_id
            case "$app_display" in
                "qBittorrent") app_id="qbittorrent" ;;
                "Jellyfin")    app_id="jellyfin" ;;
                "Plex")        app_id="plex" ;;
                "FileBrowser") app_id="filebrowser" ;;
                "rTorrent")    app_id="rtorrent" ;;
                "ruTorrent")   app_id="rutorrent" ;;
                "Tailscale")   app_id="tailscale" ;;
                *)             continue ;;
            esac
            echo
            app_install "$app_id" || true
        done <<< "$selected_apps"
    fi
    
    echo
    
    # Tuning
    if tui_confirm "Apply system tuning for optimal seedbox performance?"; then
        tune_apply_all
    fi
    
    # Nginx
    if tui_confirm "Setup Nginx reverse proxy?"; then
        nginx_install
        nginx_create_main_server
        for app in qbittorrent jellyfin plex filebrowser; do
            app_is_installed "$app" && "nginx_${app}" 2>/dev/null || true
        done
    fi
    
    # Security
    if tui_confirm "Apply SSH security hardening and firewall?"; then
        security_fail2ban || true
        firewall_setup || true
    fi
    
    echo
    
    # ─── Final Summary ───
    clear
    show_banner
    
    local ip
    ip="$(get_local_ip)"
    local username
    username="$(get_seedbox_user)"
    
    msg_header "Installation Summary"
    echo
    printf "  ${BOLD}${CYAN}┌────────────────────────────────────────────────────────┐${RESET}\n"
    printf "  ${BOLD}${CYAN}│${RESET}  ${BOLD}Server Information${RESET}                                   ${BOLD}${CYAN}│${RESET}\n"
    printf "  ${BOLD}${CYAN}├────────────────────────────────────────────────────────┤${RESET}\n"
    printf "  ${BOLD}${CYAN}│${RESET}  %-16s %-37s${BOLD}${CYAN}│${RESET}\n" "OS:" "$S4D_OS_PRETTY"
    printf "  ${BOLD}${CYAN}│${RESET}  %-16s %-37s${BOLD}${CYAN}│${RESET}\n" "Architecture:" "$S4D_ARCH"
    printf "  ${BOLD}${CYAN}│${RESET}  %-16s %-37s${BOLD}${CYAN}│${RESET}\n" "IP Address:" "$ip"
    printf "  ${BOLD}${CYAN}│${RESET}  %-16s %-37s${BOLD}${CYAN}│${RESET}\n" "Seedbox User:" "$username"
    printf "  ${BOLD}${CYAN}│${RESET}  %-16s %-37s${BOLD}${CYAN}│${RESET}\n" "RAM:" "${S4D_MEM_TOTAL_MB}MB"
    printf "  ${BOLD}${CYAN}└────────────────────────────────────────────────────────┘${RESET}\n"
    echo
    
    # Installed Apps Table
    local installed_apps
    installed_apps="$(app_list_installed)"
    
    if [[ -n "$installed_apps" ]]; then
        printf "  ${BOLD}${GREEN}┌────────────────────────────────────────────────────────┐${RESET}\n"
        printf "  ${BOLD}${GREEN}│${RESET}  ${BOLD}Installed Applications${RESET}                               ${BOLD}${GREEN}│${RESET}\n"
        printf "  ${BOLD}${GREEN}├──────────────────┬────────────┬────────────────────────┤${RESET}\n"
        printf "  ${BOLD}${GREEN}│${RESET} %-16s ${BOLD}${GREEN}│${RESET} %-10s ${BOLD}${GREEN}│${RESET} %-22s ${BOLD}${GREEN}│${RESET}\n" "Application" "Status" "Access URL"
        printf "  ${BOLD}${GREEN}├──────────────────┼────────────┼────────────────────────┤${RESET}\n"
        
        while IFS= read -r app; do
            local status port url status_color
            status="$(app_status "$app")"
            
            if [[ "$status" == "running" ]]; then
                status_color="${GREEN}"
            else
                status_color="${RED}"
            fi
            
            case "$app" in
                qbittorrent)
                    port="$(config_get S4D_QB_PORT 8080)"
                    url="http://${ip}:${port}"
                    ;;
                jellyfin)
                    port="$(config_get S4D_JELLYFIN_PORT 8096)"
                    url="http://${ip}:${port}"
                    ;;
                plex)
                    url="http://${ip}:32400/web"
                    ;;
                filebrowser)
                    port="$(config_get S4D_FILEBROWSER_PORT 8085)"
                    url="http://${ip}:${port}"
                    ;;
                rtorrent)
                    url="(SCGI - no web UI)"
                    ;;
                rutorrent)
                    port="$(config_get S4D_RUTORRENT_PORT 443)"
                    url="http://${ip}/rutorrent"
                    ;;
                tailscale)
                    local ts_ip
                    ts_ip="$(tailscale ip -4 2>/dev/null || echo 'N/A')"
                    url="IP: ${ts_ip}"
                    ;;
                *)
                    url="N/A"
                    ;;
            esac
            
            printf "  ${BOLD}${GREEN}│${RESET} %-16s ${BOLD}${GREEN}│${RESET} ${status_color}%-10s${RESET} ${BOLD}${GREEN}│${RESET} %-22s ${BOLD}${GREEN}│${RESET}\n" "$app" "$status" "$url"
        done <<< "$installed_apps"
        
        printf "  ${BOLD}${GREEN}└──────────────────┴────────────┴────────────────────────┘${RESET}\n"
    fi
    
    echo
    
    # Credentials
    printf "  ${BOLD}${YELLOW}┌────────────────────────────────────────────────────────┐${RESET}\n"
    printf "  ${BOLD}${YELLOW}│${RESET}  ${BOLD}Credentials & Access${RESET}                                ${BOLD}${YELLOW}│${RESET}\n"
    printf "  ${BOLD}${YELLOW}├────────────────────────────────────────────────────────┤${RESET}\n"
    printf "  ${BOLD}${YELLOW}│${RESET}  ${BOLD}Seedbox User:${RESET} %-40s${BOLD}${YELLOW}│${RESET}\n" "$username"
    printf "  ${BOLD}${YELLOW}│${RESET}  ${BOLD}Password:${RESET}     %-40s${BOLD}${YELLOW}│${RESET}\n" "(the password you set during user creation)"
    printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    
    if app_is_installed "qbittorrent"; then
        local qb_port
        qb_port="$(config_get S4D_QB_PORT 8080)"
        printf "  ${BOLD}${YELLOW}│${RESET}  ${CYAN}qBittorrent${RESET}                                          ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}    URL:  ${BOLD}http://${ip}:${qb_port}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((35 - ${#ip} - ${#qb_port}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}    User: ${BOLD}${username}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((45 - ${#username}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    fi
    
    if app_is_installed "jellyfin"; then
        local jf_port
        jf_port="$(config_get S4D_JELLYFIN_PORT 8096)"
        printf "  ${BOLD}${YELLOW}│${RESET}  ${CYAN}Jellyfin${RESET}                                             ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}    URL:  ${BOLD}http://${ip}:${jf_port}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((35 - ${#ip} - ${#jf_port}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}    (Complete setup via web wizard on first visit)       ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    fi
    
    if app_is_installed "plex"; then
        printf "  ${BOLD}${YELLOW}│${RESET}  ${CYAN}Plex${RESET}                                                 ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}    URL:  ${BOLD}http://${ip}:32400/web${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((25 - ${#ip}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}    (Login with your Plex account)                      ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    fi
    
    if app_is_installed "filebrowser"; then
        local fb_port
        fb_port="$(config_get S4D_FILEBROWSER_PORT 8085)"
        printf "  ${BOLD}${YELLOW}│${RESET}  ${CYAN}FileBrowser${RESET}                                          ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}    URL:  ${BOLD}http://${ip}:${fb_port}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((35 - ${#ip} - ${#fb_port}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}    User: ${BOLD}${username}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((45 - ${#username}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    fi
    
    if app_is_installed "tailscale"; then
        local ts_ip
        ts_ip="$(tailscale ip -4 2>/dev/null || echo 'not connected')"
        printf "  ${BOLD}${YELLOW}│${RESET}  ${CYAN}Tailscale${RESET}                                            ${BOLD}${YELLOW}│${RESET}\n"
        printf "  ${BOLD}${YELLOW}│${RESET}    Tailscale IP: ${BOLD}${ts_ip}${RESET}%-*s${BOLD}${YELLOW}│${RESET}\n" "$((37 - ${#ts_ip}))" ""
        printf "  ${BOLD}${YELLOW}│${RESET}                                                        ${BOLD}${YELLOW}│${RESET}\n"
    fi
    
    printf "  ${BOLD}${YELLOW}└────────────────────────────────────────────────────────┘${RESET}\n"
    echo
    
    printf "  ${BOLD}${GREEN}Setup complete!${RESET} Run ${BOLD}sudo s4dbox${RESET} to manage your seedbox.\n"
    echo
    tui_pause
}

# ─── Settings Menu ───
settings_menu() {
    while true; do
        local options=(
            "System Information"
            "User Management"
            "View Configuration"
            "View Logs"
            "About s4dbox"
            "← Back"
        )
        
        tui_draw_menu "Settings" "${options[@]}"
        local choice=$?
        
        case $choice in
            0) clear; print_system_info; tui_pause ;;
            1) prompt_user_setup; tui_pause ;;
            2)
                clear
                msg_header "Configuration"
                cat "$S4D_CONF_FILE" 2>/dev/null
                tui_pause
                ;;
            3)
                clear
                msg_header "Recent Logs"
                tail -50 "$S4D_LOG_FILE" 2>/dev/null || msg_info "No logs yet"
                tui_pause
                ;;
            4)
                clear
                show_banner
                echo "  s4dbox is a lightweight, universal seedbox management tool."
                echo "  Built with pure Bash for minimal resource usage."
                echo
                echo "  Supports: Debian, Ubuntu, Arch, Fedora, RHEL, Rocky, Alma"
                echo "  Architectures: x86_64, ARM64"
                echo
                echo "  Features:"
                echo "    - Real-time system monitoring"
                echo "    - App installation & management"
                echo "    - System tuning for optimal torrent performance"
                echo "    - Nginx reverse proxy"
                echo "    - SSH hardening & firewall"
                echo "    - Storage management"
                echo "    - Network & VPN tools"
                echo
                tui_pause
                ;;
            *) return ;;
        esac
    done
}

# ─── Main Menu Loop ───
main_menu() {
    while true; do
        clear
        show_banner
        
        local options=(
            "System Monitor"
            "Application Manager"
            "System Tuning"
            "Nginx Management"
            "Security & Firewall"
            "Storage Manager"
            "Network Manager"
            "Settings"
            "Exit"
        )
        
        tui_draw_menu "s4dbox Main Menu" "${options[@]}"
        local choice=$?
        
        case $choice in
            0) monitor_live ;;
            1) app_menu_manage ;;
            2) tune_menu ;;
            3) nginx_menu ;;
            4) security_menu ;;
            5) storage_menu ;;
            6) network_menu ;;
            7) settings_menu ;;
            8|255)
                clear
                msg_info "s4dbox exiting. Goodbye!"
                log_info "s4dbox session ended"
                exit 0
                ;;
        esac
    done
}

# ─── Help ───
show_help() {
    echo "s4dbox — Lightweight Universal Seedbox Manager v${S4D_VERSION}"
    echo
    echo "Usage: sudo s4dbox [command]"
    echo
    echo "Commands:"
    echo "  (none)      Launch interactive TUI"
    echo "  install     Run first-time guided setup"
    echo "  monitor     Open system monitor"
    echo "  tune        Apply system tuning"
    echo "  security    Run security hardening"
    echo "  status      Show installed app status"
    echo "  help        Show this help"
    echo
}

# ─── Entry Point ───
main() {
    init
    
    case "${1:-}" in
        install|setup)
            first_time_setup
            ;;
        monitor)
            monitor_live
            ;;
        tune)
            tune_apply_all
            ;;
        security)
            ssh_harden
            security_fail2ban
            firewall_setup
            ;;
        status)
            print_system_info
            echo "Installed Applications:"
            app_list_installed | while IFS= read -r app; do
                printf "  %-15s [%s]\n" "$app" "$(app_status "$app")"
            done
            ;;
        help|-h|--help)
            show_help
            ;;
        "")
            # Check if first run
            if [[ ! -f "${S4D_CONF_DIR}/.initialized" ]]; then
                first_time_setup
                touch "${S4D_CONF_DIR}/.initialized"
            fi
            main_menu
            ;;
        *)
            echo "Unknown command: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
